---
import { getBudgetPercentage } from '../../budgets/budget.utils'

interface Props {
    currentIncome : number | undefined
    totalIncome : number | undefined
    currentSpending : number | undefined
    totalSpending : number | undefined
}

const { 
    currentIncome = 0,
    totalIncome = 0,
    currentSpending = 0,
    totalSpending = 0,
} = Astro.props

const spendingRatio = currentSpending && totalSpending 
    ? currentSpending / totalSpending 
    : 0

const incomeRatio = currentIncome && totalIncome 
    ? currentIncome / totalIncome 
    : 0

const max = Math.max(currentSpending, totalSpending, currentIncome, totalIncome)
const currentIncomePercent = Math.round((currentIncome / max) * 100)
const totalIncomePercent = Math.round((totalIncome / max) * 100)
const currentSpendingPercent = Math.round((currentSpending / max) * 100)
const totalSpendingPercent = Math.round((totalSpending / max) * 100)

---

<monthly-spending-summary class="mb-2">

    <spending-total class="relative rounded-sm flex items-center justify-between py-2 pb-4 min-w-fit">
        <monthly-spending-total class="text-lg font-semibold min-w-fit">
            {`${currentSpending} / ${totalSpending} spent`}
        </monthly-spending-total>
        <total-spending-bar 
            class:list={["absolute left-0 bottom-0 h-3.75 -z-10 rounded-lg block bg-red/20 scale-y-105 origin-left progress-bar animate-progress-bar", spendingRatio > 1 && 'rounded-r-none border-r-4 border-white']}
            style={`width : ${totalSpendingPercent}%`}
        />
        <current-spending-bar 
            class="absolute left-0 bottom-0 h-3.75 -z-10 rounded-lg block bg-red/60 scale-y-105 origin-left progress-bar animate-progress-bar"
            style={`width : ${currentSpendingPercent}%`}
        />
    </spending-total>
    
    <income-total class="relative rounded-sm flex items-center justify-between py-2 pb-4 min-w-fit">
        <monthly-income-total class="text-lg font-semibold min-w-fit">
            {`${currentIncome} / ${totalIncome} total income`}
        </monthly-income-total>
        <total-income-bar 
            class:list={["absolute left-0 bottom-0 h-3.75 -z-10 rounded-lg block bg-green/20 scale-y-105 origin-left progress-bar animate-progress-bar", incomeRatio > 1 && 'rounded-r-none border-r-4 border-white']}
            style={`width : ${totalIncomePercent}%`}
        />
        <current-income-bar 
            class="absolute left-0 bottom-0 h-3.75 -z-10 rounded-lg block bg-green/60 scale-y-105 origin-left progress-bar animate-progress-bar"
            style={`width : ${currentIncomePercent}%`}
        />
    </income-total>

</monthly-spending-summary>
